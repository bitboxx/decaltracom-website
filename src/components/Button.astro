---
// src/components/Button.astro
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'white' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  class?: string;
}

const { 
  href, 
  variant = 'primary', 
  size = 'md', 
  type = 'button',
  disabled = false,
  class: className = '' 
} = Astro.props;

const baseClasses = 'font-semibold shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 transition-colors';

const variants = {
  primary: 'bg-primary-500 text-white hover:bg-black focus-visible:outline-primary-500',
  secondary: 'bg-gray-600 text-white hover:bg-gray-500 focus-visible:outline-gray-600',
  white: 'bg-white text-gray-900 hover:bg-gray-100 focus-visible:outline-white',
  ghost: 'text-gray-900 hover:text-gray-600 shadow-none focus-visible:outline-gray-900'
};

const sizes = {
  sm: 'px-2.5 py-1.5 text-xs rounded',
  md: 'px-3.5 py-2.5 text-sm rounded-md',
  lg: 'px-4 py-3 text-base rounded-md'
};

const classes = `${baseClasses} ${variants[variant]} ${sizes[size]} ${className}`;

const Component = href ? 'a' : 'button';
---

<Component 
  href={href}
  type={href ? undefined : type}
  disabled={disabled}
  class={classes}
>
  <slot />
</Component>
