---
// src/components/LogoCloud.astro
interface Logo {
  src: string;
  alt: string;
  width?: number;
  height?: number;
}

interface Props {
  title: string;
  logos: Logo[];
}

const { title, logos } = Astro.props;
---

<div class='bg-white my-24 sm:my-32'>
  <div class='mx-auto max-w-7xl px-6 lg:px-8'>
    <h2 class='text-center text-lg/8 font-semibold text-gray-900'>{title}</h2>
    <div
      class='mx-auto mt-10 flex flex-wrap items-center justify-center gap-x-12 gap-y-12 sm:gap-x-16 lg:gap-x-20'
    >
      {
        logos.map((logo) => (
          <img
            class='max-h-12 w-auto max-w-[158px] object-contain'
            src={logo.src}
            alt={logo.alt}
            width={logo.width || 158}
            height={logo.height || 48}
            loading='lazy'
          />
        ))
      }
    </div>
  </div>
</div>
