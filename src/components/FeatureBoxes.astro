---
// src/components/FeatureBoxes.astro
interface FeatureBoxItem {
  title: string;
  description: string;
  imageUrl?: string;
  altText?: string;
  ctaText?: string;
  ctaUrl?: string;
}

interface Props {
  features: FeatureBoxItem[];
}

const { features } = Astro.props;
---

<div class='my-24 sm:my-32'>
  <div class='mx-auto max-w-2xl px-6 lg:max-w-7xl lg:px-8'>
    <div class='grid grid-cols-1 gap-4 lg:grid-cols-3'>
      {
        features.map((feature, index) => (
          <div
            class={`relative lg:col-span-1 ${
              index === 0 ? 'lg:rounded-bl-4xl' : ''
            } ${
              index === features.length - 1
                ? 'max-lg:rounded-b-4xl lg:rounded-br-4xl'
                : ''
            }`}
          >
            <div
              class={`absolute inset-px rounded-lg bg-white ${
                index === 0 ? 'lg:rounded-bl-4xl' : ''
              } ${
                index === features.length - 1
                  ? 'max-lg:rounded-b-4xl lg:rounded-br-4xl'
                  : ''
              }`}
            />
            <div
              class={`relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)] ${
                index === 0 ? 'lg:rounded-bl-[calc(2rem+1px)]' : ''
              } ${
                index === features.length - 1
                  ? 'max-lg:rounded-b-[calc(2rem+1px)] lg:rounded-br-[calc(2rem+1px)]'
                  : ''
              }`}
            >
              {feature.imageUrl && (
                <img
                  class={`h-80 object-cover ${index === 0 ? 'object-left' : ''}`}
                  src={feature.imageUrl}
                  alt={feature.altText || ''}
                />
              )}
              <div class='flex flex-col flex-grow p-10 pt-8'>
                <h3 class='text-sm/4 font-semibold text-primary-500'>
                  {feature.title}
                </h3>
                <p class='mt-2 text-lg font-medium tracking-tight text-gray-950'>
                  {/* This part was a subtitle in the original, mapping to description for now */}
                  {feature.description}
                </p>
                <p class='mt-2 max-w-lg text-sm/6 text-gray-600 mb-4'>
                  {/* This was the main paragraph, let's use description here too or add another prop */}
                  {feature.description}
                </p>
                {feature.ctaText && (
                  <a
                    href={feature.ctaUrl || '#'}
                    class='mt-auto flex w-full justify-center rounded-md bg-white px-3 py-1.5 text-sm/6 font-semibold text-gray-900 hover:bg-gray-50 ring-1 ring-inset ring-gray-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-600'
                  >
                    {feature.ctaText}
                  </a>
                )}
              </div>
            </div>
            <div
              class={`pointer-events-none absolute inset-px rounded-lg shadow-sm ring-1 ring-black/5 ${
                index === 0 ? 'lg:rounded-bl-4xl' : ''
              } ${
                index === features.length - 1
                  ? 'max-lg:rounded-b-4xl lg:rounded-br-4xl'
                  : ''
              }`}
            />
          </div>
        ))
      }
    </div>
  </div>
</div>
