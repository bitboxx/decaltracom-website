---
import Button from '@/components/Button.astro';

interface Props {
  title: string;
  subtitle: string;
  submitButtonText: string;
}

const { title, subtitle, submitButtonText } = Astro.props;

const lang = Astro.currentLocale || 'en';

const labels = {
  en: {
    name: 'Name',
    company: 'Company',
    email: 'Email',
    phoneNumber: 'Phone number',
    message: 'Message',
  },
  nl: {
    name: 'Naam',
    company: 'Bedrijf',
    email: 'E-mailadres',
    phoneNumber: 'Telefoonnummer',
    message: 'Bericht',
  },
};

const currentLabels = labels[lang as keyof typeof labels] || labels.en;
---

<div class='isolate bg-white px-6 py-24 sm:py-32 lg:px-8'>
  <div
    class='absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80'
    aria-hidden='true'
  >
    <div
      class='relative left-1/2 -z-10 aspect-1155/678 w-144.5 max-w-none -translate-x-1/2 rotate-30 bg-gradient-to-tr from-primary-400 to-primary-200 opacity-30 sm:left-[calc(50%-40rem)] sm:w-288.75'
      style='clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)'
    >
    </div>
  </div>
  <div class='mx-auto max-w-2xl text-center'>
    <h2
      class='text-4xl font-semibold tracking-tight text-balance text-gray-900 sm:text-5xl'
    >
      {title}
    </h2>
    <p class='mt-2 text-lg/8 text-gray-600'>{subtitle}</p>
  </div>
  <form
    id='contactForm'
    action='#'
    method='POST'
    class='mx-auto mt-16 max-w-xl sm:mt-20'
  >
    <input
      type='hidden'
      name='language'
      value={lang === 'nl' ? 'nl-nl' : 'en-gb'}
    />
    <div class='grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2'>
      <div class='sm:col-span-2'>
        <label for='name' class='block text-sm/6 font-semibold text-gray-900'
          >{currentLabels.name}</label
        >
        <div class='mt-2.5'>
          <input
            type='text'
            name='name'
            id='name'
            autocomplete='name'
            class='block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-primary-500'
          />
        </div>
      </div>
      <div class='sm:col-span-2'>
        <label for='company' class='block text-sm/6 font-semibold text-gray-900'
          >{currentLabels.company}</label
        >
        <div class='mt-2.5'>
          <input
            type='text'
            name='company'
            id='company'
            autocomplete='organization'
            class='block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-primary-500'
          />
        </div>
      </div>
      <div class='sm:col-span-2'>
        <label for='email' class='block text-sm/6 font-semibold text-gray-900'
          >{currentLabels.email}</label
        >
        <div class='mt-2.5'>
          <input
            type='email'
            name='email'
            id='email'
            autocomplete='email'
            class='block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-primary-500'
          />
        </div>
      </div>
      <div class='sm:col-span-2'>
        <label
          for='phone-number'
          class='block text-sm/6 font-semibold text-gray-900'
          >{currentLabels.phoneNumber}</label
        >
        <div class='mt-2.5'>
          <input
            type='text'
            name='phone-number'
            id='phone-number'
            autocomplete='tel'
            class='block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-primary-500'
            placeholder='+31 6 0000 0000'
          />
        </div>
      </div>
      <div class='sm:col-span-2'>
        <label for='message' class='block text-sm/6 font-semibold text-gray-900'
          >{currentLabels.message}</label
        >
        <div class='mt-2.5'>
          <textarea
            name='message'
            id='message'
            rows='4'
            class='block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-primary-500'
          ></textarea>
        </div>
      </div>
    </div>
    <div class='mt-10'>
      <Button type='submit' class='block w-full text-center'>
        {submitButtonText}
      </Button>
    </div>
  </form>

  <script>
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const initTime = Date.now();
    const MINIMUM_WAIT_MS = 5000;

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const elapsedTime = Date.now() - initTime;
        if (elapsedTime < MINIMUM_WAIT_MS) {
          return;
        }

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        try {
          const response = await fetch(
            'https://cf-web-mailer.bbee.workers.dev',
            {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                name: data.name,
                email: data.email,
                message: data.message,
                company: data.company,
                phone: data['phone-number'],
                language: data.language,
              }),
            },
          );

          if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
          }

          // Reset form on success
          form.reset();
        } catch (error) {
          console.error('Error:', error);
        }
      });
    }
  </script>
</div>
