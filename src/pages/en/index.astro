    ctaText: 'Discover nearshoring',
    ctaUrl: getRelativeLocaleUrl('en', 'services/nearshoring'),
    learnMoreText: 'More about nearshoring',
    learnMoreUrl: getRelativeLocaleUrl('en', 'services/nearshoring'),
  },
  {
    id: 'ai-solutions',
    title: 'AI for Efficient Organisations',
    description: 'Let AI strengthen your team, streamline processes and reduce costs with practical, directly applicable solutions. From automation to intelligent data analysis.',
    ctaText: 'Discover AI solutions',
    ctaUrl: getRelativeLocaleUrl('en', 'services/ai-for-efficient-organisations'),
    learnMoreText: 'More about AI',
