    description: 'With over 15 years of experience, we deliver digital solutions that do exactly what your organisation needs. From concept to delivery, we provide quality software that grows with your business.',
    ctaText: 'View our services',
    ctaUrl: getRelativeLocaleUrl('en', 'services/software-development'),
    learnMoreText: 'More about development',
    learnMoreUrl: getRelativeLocaleUrl('en', 'services/software-development'),
  },
  {
    id: 'nearshoring',
    title: 'Nearshoring from the UK',
