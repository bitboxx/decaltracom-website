---
import GlobalLayout from '@/layouts/GlobalLayout.astro';
import HeadingBlockSimple from '@/components/HeadingBlockSimple.astro';
---

<GlobalLayout
  lang='en'
  title='AI for Efficient Organisations'
  description='Let AI strengthen your team, streamline processes and reduce costs.'
>
  <HeadingBlockSimple
    title='Do more with less – thanks to AI'
    subTitle='Let AI strengthen your team, streamline processes and reduce costs. We help you integrate AI smartly into your business operations – bespoke, practical, and without empty promises.'
    background='/images/grey-with-leaves.jpg'
  />

  <div class='bg-white px-6 py-32 lg:px-8'>
    <div class='mx-auto max-w-3xl text-base/7 text-gray-700'>
      <p class='text-base/7 font-semibold text-primary-500'>
        AI for Efficient Organisations
      </p>
      <h1
        class='mt-2 text-4xl font-bold tracking-tight text-pretty text-gray-900 sm:text-5xl'
      >
        From customer service to data analysis: we make your processes smarter,
        faster and more scalable
      </h1>
      <div class='mt-10 max-w-2xl'>
        <ul role='list' class='mt-8 max-w-xl space-y-8 text-gray-600'>
          <li class='flex gap-x-3'>
            <svg
              class='mt-1 size-5 flex-none text-primary-500'
              viewBox='0 0 20 20'
              fill='currentColor'
              aria-hidden='true'
              data-slot='icon'
            >
              <path
                fill-rule='evenodd'
                d='M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z'
                clip-rule='evenodd'></path>
            </svg>
            <span
              ><strong class='font-semibold text-gray-900'>Efficiency</strong>
              {' > '}Automate repetitive work and save time.</span
            >
          </li>
          <li class='flex gap-x-3'>
            <svg
              class='mt-1 size-5 flex-none text-primary-500'
              viewBox='0 0 20 20'
              fill='currentColor'
              aria-hidden='true'
              data-slot='icon'
            >
              <path
                fill-rule='evenodd'
                d='M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z'
                clip-rule='evenodd'></path>
            </svg>
            <span
              ><strong class='font-semibold text-gray-900'>Cost savings</strong>
              {' > '}Reduce staff pressure without compromising output.</span
            >
          </li>
          <li class='flex gap-x-3'>
            <svg
              class='mt-1 size-5 flex-none text-primary-500'
              viewBox='0 0 20 20'
              fill='currentColor'
              aria-hidden='true'
              data-slot='icon'
            >
              <path
                fill-rule='evenodd'
                d='M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z'
                clip-rule='evenodd'></path>
            </svg>
            <span
              ><strong class='font-semibold text-gray-900'
                >Quick adoption</strong
              >
              {' > '}We integrate AI into your existing tools and workflows.</span
            >
          </li>
        </ul>
        <div class='mt-10 flex items-center gap-x-6'>
          <a
            href='/en/contact'
            class='rounded-md bg-primary-500 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-black hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500'
          >
            Start an AI project
          </a>
          <a
            href='#process'
            class='text-sm font-semibold leading-6 text-gray-900'
          >
            Our approach <span aria-hidden='true'>→</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Features Section -->
  <div class='bg-white py-24 sm:py-32'>
    <div class='mx-auto max-w-7xl px-6 lg:px-8'>
      <div class='mx-auto max-w-2xl lg:text-center'>
        <h2 class='text-base font-semibold leading-7 text-primary-500'>
          Practical applications
        </h2>
        <p
          class='mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl'
        >
          Where AI delivers results today
        </p>
      </div>
      <div class='mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-4xl'>
        <dl
          class='grid max-w-xl grid-cols-1 gap-x-8 gap-y-10 lg:max-w-none lg:grid-cols-2 lg:gap-y-16'
        >
          <div class='relative pl-16'>
            <dt class='text-base font-semibold leading-7 text-gray-900'>
              <div
                class='absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500'
              >
                <svg
                  class='h-6 w-6 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke-width='1.5'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z'
                  ></path>
                </svg>
              </div>
              Customer service
            </dt>
            <dd class='mt-2 text-base leading-7 text-gray-600'>
              AI chatbots and automatic email replies for faster and more
              consistent customer service.
            </dd>
          </div>
          <div class='relative pl-16'>
            <dt class='text-base font-semibold leading-7 text-gray-900'>
              <div
                class='absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500'
              >
                <svg
                  class='h-6 w-6 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke-width='1.5'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25'
                  ></path>
                </svg>
              </div>
              Internal knowledge sharing
            </dt>
            <dd class='mt-2 text-base leading-7 text-gray-600'>
              AI search across documents and policies for better access to
              company knowledge.
            </dd>
          </div>
          <div class='relative pl-16'>
            <dt class='text-base font-semibold leading-7 text-gray-900'>
              <div
                class='absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500'
              >
                <svg
                  class='h-6 w-6 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke-width='1.5'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z'
                  ></path>
                </svg>
              </div>
              Document processing
            </dt>
            <dd class='mt-2 text-base leading-7 text-gray-600'>
              Reports, minutes and files compressed and analysed at lightning
              speed.
            </dd>
          </div>
          <div class='relative pl-16'>
            <dt class='text-base font-semibold leading-7 text-gray-900'>
              <div
                class='absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500'
              >
                <svg
                  class='h-6 w-6 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke-width='1.5'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 11.25v1.5m3-1.5v1.5'
                  ></path>
                </svg>
              </div>
              Data analysis
            </dt>
            <dd class='mt-2 text-base leading-7 text-gray-600'>
              Large amounts of data smartly organised for better
              decision-making.
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </div>

  <!-- Process Section -->
  <div id='process' class='bg-gray-50 py-24 sm:py-32'>
    <div class='mx-auto max-w-7xl px-6 lg:px-8'>
      <div class='mx-auto max-w-2xl lg:text-center'>
        <h2 class='text-base font-semibold leading-7 text-primary-500'>
          Our Approach
        </h2>
        <p
          class='mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl'
        >
          How we integrate AI into your organisation
        </p>
      </div>
      <div class='mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-none'>
        <dl
          class='grid max-w-xl grid-cols-1 gap-x-8 gap-y-16 lg:max-w-none lg:grid-cols-3'
        >
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                1
              </div>
              Analysis & quick scan
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>
                We identify where AI directly adds value to your organisation.
              </p>
            </dd>
          </div>
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                2
              </div>
              Proof of concept
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>
                We test a concrete application in your specific context.
              </p>
            </dd>
          </div>
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                3
              </div>
              Integration
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>
                We smartly connect AI to existing systems and workflows.
              </p>
            </dd>
          </div>
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                4
              </div>
              Training & support
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>
                Your team learns to work with it, we remain available for
                support.
              </p>
            </dd>
          </div>
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                5
              </div>
              Optimisation
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>
                We measure impact and continuously improve.
              </p>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </div>

  <!-- Call to Action Section -->
  <div id='contact' class='bg-primary-500'>
    <div class='px-6 py-24 sm:px-6 sm:py-32 lg:px-8'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-3xl font-bold tracking-tight text-white sm:text-4xl'>
          Let your business run on smart technology
        </h2>
        <p class='mx-auto mt-6 max-w-xl text-lg leading-8 text-indigo-200'>
          AI is not future music. It's already here – and you can benefit from
          it today.
        </p>
        <p class='mx-auto mt-4 max-w-xl text-lg leading-8 text-indigo-200'>
          Request a free AI scan and discover what "doing more with less" means
          in your context.
        </p>
        <div class='mt-10 flex items-center justify-center gap-x-6'>
          <a
            href='/en/contact'
            class='rounded-md bg-white px-3.5 py-2.5 text-sm font-semibold text-primary-500 shadow-sm hover:bg-black hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white'
          >
            Schedule an exploratory conversation
          </a>
        </div>
      </div>
    </div>
  </div>
</GlobalLayout>
