---
import { getRelativeLocaleUrl } from 'astro:i18n';
import GlobalLayout from '@/layouts/GlobalLayout.astro';
import HeadingBlockSimple from '@/components/HeadingBlockSimple.astro';
import LogoCloud from '@/components/LogoCloud.astro';
---

<GlobalLayout
  lang='en'
  title='Software Development Services'
  description='Bespoke web applications with over 15 years of experience. JavaScript, TypeScript, React and Node.js development.'
>
  <HeadingBlockSimple
    title='Bespoke Web Application Development on a Project Basis'
    subTitle='With over 15 years of experience, we deliver digital solutions on a project basis that do exactly what your organisation needs.'
    background='/images/developers2.jpeg'
  />

  <div class='bg-white px-6 py-32 lg:px-8'>
    <div class='mx-auto max-w-3xl text-base/7 text-gray-700'>
      <p class='text-base/7 font-semibold text-primary-500'>
        Leading Expertise
      </p>
      <h1
        class='mt-2 text-4xl font-bold tracking-tight text-pretty text-gray-900 sm:text-5xl'
      >
        Digital Solutions with Impact
      </h1>
      <p class='mt-6 text-xl/8'>
        Whether you are a large enterprise or an ambitious startup, we deliver
        digital solutions on a project basis with JavaScript/TypeScript, built
        on frameworks like React and Node.js.
      </p>
      <div class='mt-10 max-w-2xl'>
        <p>
          With over 15 years of experience and projects for clients including
          Interpolis/Achmea, NPO, SBS Broadcasting and beslist.nl, we know how
          to deliver quality you can trust. Focus on quality is central to
          everything we do – from the first meeting to delivery.
        </p>
        <ul role='list' class='mt-8 max-w-xl space-y-8 text-gray-600'>
          <li class='flex gap-x-3'>
            <svg
              class='mt-1 size-5 flex-none text-primary-500'
              viewBox='0 0 20 20'
              fill='currentColor'
              aria-hidden='true'
              data-slot='icon'
            >
              <path
                fill-rule='evenodd'
                d='M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z'
                clip-rule='evenodd'></path>
            </svg>
            <span
              ><strong class='font-semibold text-gray-900'
                >Experienced Team.</strong
              > A team with over 15 years of experience in building complex web applications.</span
            >
          </li>
          <li class='flex gap-x-3'>
            <svg
              class='mt-1 size-5 flex-none text-primary-500'
              viewBox='0 0 20 20'
              fill='currentColor'
              aria-hidden='true'
              data-slot='icon'
            >
              <path
                fill-rule='evenodd'
                d='M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z'
                clip-rule='evenodd'></path>
            </svg>
            <span
              ><strong class='font-semibold text-gray-900'
                >Modern Technologies.</strong
              > We work with the latest tools and frameworks such as React, TypeScript
              and Node.js.</span
            >
          </li>
          <li class='flex gap-x-3'>
            <svg
              class='mt-1 size-5 flex-none text-primary-500'
              viewBox='0 0 20 20'
              fill='currentColor'
              aria-hidden='true'
              data-slot='icon'
            >
              <path
                fill-rule='evenodd'
                d='M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z'
                clip-rule='evenodd'></path>
            </svg>
            <span
              ><strong class='font-semibold text-gray-900'
                >Quality Focus.</strong
              > High-quality code and extensive testing guarantee reliable applications.</span
            >
          </li>
        </ul>
        <div class='mt-10 flex items-center gap-x-6'>
          <a
            href='/en/contact'
            class='rounded-md bg-primary-500 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-black hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500'
          >
            Start your project
          </a>
          <a
            href='#process'
            class='text-sm font-semibold leading-6 text-gray-900'
          >
            Our approach <span aria-hidden='true'>→</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Features Section -->
  <div class='bg-white py-24 sm:py-32'>
    <div class='mx-auto max-w-7xl px-6 lg:px-8'>
      <div class='mx-auto max-w-2xl lg:text-center'>
        <h2 class='text-base font-semibold leading-7 text-primary-500'>
          Our Advantages
        </h2>
        <p
          class='mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl'
        >
          Why choose our expertise?
        </p>
      </div>
      <div class='mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-4xl'>
        <dl
          class='grid max-w-xl grid-cols-1 gap-x-8 gap-y-10 lg:max-w-none lg:grid-cols-2 lg:gap-y-16'
        >
          <div class='relative pl-16'>
            <dt class='text-base font-semibold leading-7 text-gray-900'>
              <div
                class='absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500'
              >
                <svg
                  class='h-6 w-6 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke-width='1.5'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z'></path>
                </svg>
              </div>
              Over 15 years of experience
            </dt>
            <dd class='mt-2 text-base leading-7 text-gray-600'>
              A development partner that has been building web applications for
              more than a decade and a half. You see that expertise reflected in
              the end result.
            </dd>
          </div>
          <div class='relative pl-16'>
            <dt class='text-base font-semibold leading-7 text-gray-900'>
              <div
                class='absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500'
              >
                <svg
                  class='h-6 w-6 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke-width='1.5'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M9.497 14.25v-.916c0-1.18.956-2.125 2.125-2.125a2.13 2.13 0 0 1 2.125 2.125v.916m-7.5 0a48.667 48.667 0 0 1 7.5 0'
                  ></path>
                </svg>
              </div>
              Big names trust us
            </dt>
            <dd class='mt-2 text-base leading-7 text-gray-600'>
              We have delivered successful projects for organisations such as
              Interpolis/Achmea, NPO and SBS Broadcasting. We know the
              challenges and the solutions.
            </dd>
          </div>
          <div class='relative pl-16'>
            <dt class='text-base font-semibold leading-7 text-gray-900'>
              <div
                class='absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500'
              >
                <svg
                  class='h-6 w-6 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke-width='1.5'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5'
                  ></path>
                </svg>
              </div>
              Modern tech stack
            </dt>
            <dd class='mt-2 text-base leading-7 text-gray-600'>
              We develop with modern tools and languages such as JavaScript,
              TypeScript, React and Node.js. This guarantees fast, stable and
              future-proof applications.
            </dd>
          </div>
          <div class='relative pl-16'>
            <dt class='text-base font-semibold leading-7 text-gray-900'>
              <div
                class='absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500'
              >
                <svg
                  class='h-6 w-6 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke-width='1.5'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.623 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z'
                  ></path>
                </svg>
              </div>
              Quality & reliability
            </dt>
            <dd class='mt-2 text-base leading-7 text-gray-600'>
              Our code is thoroughly tested and follows high standards. This
              gives you a solid product that is ready for growth.
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </div>

  <LogoCloud
    title='Trusted by:'
    logos={[
      {
        src: '/clients/achmea.svg',
        alt: 'Achmea',
      },
      {
        src: '/clients/rabobank.svg',
        alt: 'Rabobank',
      },
      {
        src: '/clients/prorail.svg',
        alt: 'ProRail',
      },
      {
        src: '/clients/npo.svg',
        alt: 'NPO',
      },
      {
        src: '/clients/sbs.svg',
        alt: 'SBS',
      },
      {
        src: '/clients/beslistnl.svg',
        alt: 'Beslist.nl',
      },
    ]}
  />

  <!-- Process Section -->
  <div id='process' class='bg-gray-50 py-24 sm:py-32'>
    <div class='mx-auto max-w-7xl px-6 lg:px-8'>
      <div class='mx-auto max-w-2xl lg:text-center'>
        <h2 class='text-base font-semibold leading-7 text-primary-500'>
          Our Approach
        </h2>
        <p
          class='mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl'
        >
          From idea to working application
        </p>
      </div>
      <div class='mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-none'>
        <dl
          class='grid max-w-xl grid-cols-1 gap-x-8 gap-y-16 lg:max-w-none lg:grid-cols-3'
        >
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                1
              </div>
              Assessment & advice
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>
                We start with an introduction in which we discuss your ideas and
                goals and advise on the best approach.
              </p>
            </dd>
          </div>
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                2
              </div>
              Design & prototyping
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>
                We translate your wishes into a concrete design. Through
                wireframes and prototypes, you get early insight into what the
                application will look like.
              </p>
            </dd>
          </div>
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                3
              </div>
              Development
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>
                Our developers start building. We work in short sprints, so you
                see interim results and can give feedback.
              </p>
            </dd>
          </div>
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                4
              </div>
              Testing & quality control
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>
                No surprises at launch: we test thoroughly on all fronts.
              </p>
            </dd>
          </div>
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                5
              </div>
              Delivery & support
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>
                After delivery, we help with going live and remain available for
                support, updates and new features.
              </p>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </div>

  <!-- Testimonials Section -->
  <div class='bg-white py-24 sm:py-32'>
    <div class='mx-auto max-w-7xl px-6 lg:px-8'>
      <div class='mx-auto max-w-xl text-center'>
        <h2
          class='text-lg font-semibold leading-8 tracking-tight text-primary-500'
        >
          Experiences
        </h2>
        <p
          class='mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl'
        >
          What our clients say
        </p>
      </div>
      <div
        class='mx-auto mt-16 flow-root max-w-2xl sm:mt-20 lg:mx-0 lg:max-w-none'
      >
        <div class='grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-2'>
          <div class='rounded-2xl bg-gray-50 p-8'>
            <figure class='h-full flex flex-col justify-between'>
              <blockquote class='text-lg leading-8 text-gray-900'>
                <p>
                  "The collaboration was professional and pleasant from start to
                  finish. The team thought proactively and delivered a web
                  application that exceeded our expectations. Quality and
                  communication were top-notch!"
                </p>
              </blockquote>
              <figcaption class='mt-6 flex items-center gap-x-4'>
                <div
                  class='h-10 w-10 rounded-full bg-primary-500 flex items-center justify-center'
                >
                  <span class='text-sm font-medium text-white'>PO</span>
                </div>
                <div class='text-sm leading-6'>
                  <div class='font-semibold text-gray-900'>Product Owner</div>
                  <div class='text-gray-600'>at a satisfied client</div>
                </div>
              </figcaption>
            </figure>
          </div>
          <div class='rounded-2xl bg-gray-50 p-8'>
            <figure class='h-full flex flex-col justify-between'>
              <blockquote class='text-lg leading-8 text-gray-900'>
                <p>
                  "Thanks to their expertise in React and Node, we were able to
                  scale quickly. Our application runs stably and the user
                  experience is excellent. This partner is a real asset for
                  bespoke projects."
                </p>
              </blockquote>
              <figcaption class='mt-6 flex items-center gap-x-4'>
                <div
                  class='h-10 w-10 rounded-full bg-primary-500 flex items-center justify-center'
                >
                  <span class='text-sm font-medium text-white'>CTO</span>
                </div>
                <div class='text-sm leading-6'>
                  <div class='font-semibold text-gray-900'>CTO</div>
                  <div class='text-gray-600'>of a scale-up</div>
                </div>
              </figcaption>
            </figure>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Call to Action Section -->
  <div id='contact' class='bg-primary-500'>
    <div class='px-6 py-24 sm:px-6 sm:py-32 lg:px-8'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-3xl font-bold tracking-tight text-white sm:text-4xl'>
          Ready to turn your idea into a strong web application?
        </h2>
        <p class='mx-auto mt-6 max-w-xl text-lg leading-8 text-indigo-200'>
          Contact us today for a free consultation. We would be happy to discuss
          your challenge and show how our expertise can take your project to the
          next level.
        </p>
        <p class='mx-auto mt-4 max-w-xl text-lg leading-8 text-indigo-200'>
          Whether you are an established company or a promising startup, we are
          ready to create something beautiful together.
        </p>
        <div class='mt-10 flex items-center justify-center gap-x-6'>
          <a
            href={getRelativeLocaleUrl('en', 'contact')}
            class='rounded-md bg-white px-3.5 py-2.5 text-sm font-semibold text-primary-500 shadow-sm hover:bg-black hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white'
          >
            Get in touch
          </a>
        </div>
      </div>
    </div>
  </div>
</GlobalLayout>
