---
import { getImage } from 'astro:assets'
import Layout from '../layouts/Layout.astro'
import HomePage from '@/components/pages/HomePage'
import heroImage from '../assets/images/european-cityscape-cropped.jpg'

const optimizedHero = await getImage({ src: heroImage, format: 'webp', width: 1920 })
---

<Layout title="DecAltra - AI-enabled decision infrastructure for capital providers">
  <HomePage client:load heroImageSrc={optimizedHero.src} />
</Layout>
