---
import GlobalLayout from '@/layouts/GlobalLayout.astro';
import HeadingBlockSimple from '@/components/HeadingBlockSimple.astro';
import CallToActionSimple from '@/components/CallToActionSimple.astro';
import Button from '@/components/Button.astro';
---

<GlobalLayout
  lang='nl'
  title='AI voor Efficiëntere Organisaties'
  description='Laat AI je team versterken, processen stroomlijnen en kosten verlagen.'
>
  <HeadingBlockSimple
    title='Meer doen met minder – dankzij AI'
    subTitle='Laat AI je team versterken, processen stroomlijnen en kosten verlagen. Wij helpen je AI slim te integreren in je bedrijfsvoering – op maat, praktisch, en zonder loze beloftes.'
    background='/images/do-more.jpg'
    showDecoration={false}
  />

  <div class='bg-white px-6 py-32 lg:px-8'>
    <div class='mx-auto max-w-3xl text-base/7 text-gray-700'>
      <p class='text-base/7 font-semibold text-primary-500'>
        AI voor Efficiëntere Organisaties
      </p>
      <h1
        class='mt-2 text-4xl font-bold tracking-tight text-pretty text-gray-900 sm:text-5xl'
      >
        Van klantenservice tot data-analyse: wij maken jouw processen slimmer,
        sneller en schaalbaarder
      </h1>
      <div class='mt-10 max-w-2xl'>
        <ul role='list' class='mt-8 max-w-xl space-y-8 text-gray-600'>
          <li class='flex gap-x-3'>
            <svg
              class='mt-1 size-5 flex-none text-primary-500'
              viewBox='0 0 20 20'
              fill='currentColor'
              aria-hidden='true'
              data-slot='icon'
            >
              <path
                fill-rule='evenodd'
                d='M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z'
                clip-rule='evenodd'></path>
            </svg>
            <span
              ><strong class='font-semibold text-gray-900'>Efficiëntie</strong>
              {' > '}Automatiseer repeterend werk en win tijd.</span
            >
          </li>
          <li class='flex gap-x-3'>
            <svg
              class='mt-1 size-5 flex-none text-primary-500'
              viewBox='0 0 20 20'
              fill='currentColor'
              aria-hidden='true'
              data-slot='icon'
            >
              <path
                fill-rule='evenodd'
                d='M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z'
                clip-rule='evenodd'></path>
            </svg>
            <span
              ><strong class='font-semibold text-gray-900'
                >Kostenbesparing</strong
              >
              {' > '}Verlaag personeelsdruk zonder in te leveren op output.</span
            >
          </li>
          <li class='flex gap-x-3'>
            <svg
              class='mt-1 size-5 flex-none text-primary-500'
              viewBox='0 0 20 20'
              fill='currentColor'
              aria-hidden='true'
              data-slot='icon'
            >
              <path
                fill-rule='evenodd'
                d='M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z'
                clip-rule='evenodd'></path>
            </svg>
            <span
              ><strong class='font-semibold text-gray-900'
                >Snelle adoptie</strong
              >
              {' > '}We integreren AI in je bestaande tools en werkwijzen.</span
            >
          </li>
        </ul>
        <div class='mt-10 flex items-center gap-x-6'>
          <a
            href='/nl/contact'
            class='rounded-md bg-primary-500 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-black hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500'
          >
            Start een AI-project
          </a>
          <a
            href='#process'
            class='text-sm font-semibold leading-6 text-gray-900'
          >
            Onze aanpak <span aria-hidden='true'>→</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Features Section -->
  <div class='bg-white py-24 sm:py-32'>
    <div class='mx-auto max-w-7xl px-6 lg:px-8'>
      <div class='mx-auto max-w-2xl lg:text-center'>
        <h2 class='text-base font-semibold leading-7 text-primary-500'>
          Praktische toepassingen
        </h2>
        <p
          class='mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl'
        >
          Waar AI vandaag al rendeert
        </p>
      </div>
      <div class='mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-4xl'>
        <dl
          class='grid max-w-xl grid-cols-1 gap-x-8 gap-y-10 lg:max-w-none lg:grid-cols-2 lg:gap-y-16'
        >
          <div class='relative pl-16'>
            <dt class='text-base font-semibold leading-7 text-gray-900'>
              <div
                class='absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500'
              >
                <svg
                  class='h-6 w-6 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke-width='1.5'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z'
                  ></path>
                </svg>
              </div>
              Klantenservice
            </dt>
            <dd class='mt-2 text-base leading-7 text-gray-600'>
              AI-chatbots en automatische e-mailreplies voor snellere en
              consistentere klantenservice.
            </dd>
          </div>
          <div class='relative pl-16'>
            <dt class='text-base font-semibold leading-7 text-gray-900'>
              <div
                class='absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500'
              >
                <svg
                  class='h-6 w-6 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke-width='1.5'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25'
                  ></path>
                </svg>
              </div>
              Interne kennisdeling
            </dt>
            <dd class='mt-2 text-base leading-7 text-gray-600'>
              AI-search over documenten en policies voor betere toegang tot
              bedrijfskennis.
            </dd>
          </div>
          <div class='relative pl-16'>
            <dt class='text-base font-semibold leading-7 text-gray-900'>
              <div
                class='absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500'
              >
                <svg
                  class='h-6 w-6 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke-width='1.5'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z'
                  ></path>
                </svg>
              </div>
              Document verwerking
            </dt>
            <dd class='mt-2 text-base leading-7 text-gray-600'>
              Rapporten, notulen en dossiers razendsnel gecomprimeerd en
              geanalyseerd.
            </dd>
          </div>
          <div class='relative pl-16'>
            <dt class='text-base font-semibold leading-7 text-gray-900'>
              <div
                class='absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500'
              >
                <svg
                  class='h-6 w-6 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke-width='1.5'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 11.25v1.5m3-1.5v1.5'
                  ></path>
                </svg>
              </div>
              Data-analyse
            </dt>
            <dd class='mt-2 text-base leading-7 text-gray-600'>
              Grote hoeveelheden data slim geordend voor betere besluitvorming.
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </div>

  <!-- Process Section -->
  <div id='process' class='bg-gray-50 py-24 sm:py-32'>
    <div class='mx-auto max-w-7xl px-6 lg:px-8'>
      <div class='mx-auto max-w-2xl lg:text-center'>
        <h2 class='text-base font-semibold leading-7 text-primary-500'>
          Onze Aanpak
        </h2>
        <p
          class='mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl'
        >
          Hoe wij AI integreren in jouw organisatie
        </p>
      </div>
      <div class='mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-none'>
        <dl
          class='grid max-w-xl grid-cols-1 gap-x-8 gap-y-16 lg:max-w-none lg:grid-cols-3'
        >
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                1
              </div>
              Analyse & quick scan
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>
                We identificeren waar AI direct waarde toevoegt aan jouw
                organisatie.
              </p>
            </dd>
          </div>
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                2
              </div>
              Proof of concept
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>
                We testen een concrete toepassing in jouw specifieke context.
              </p>
            </dd>
          </div>
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                3
              </div>
              Integratie
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>
                We koppelen AI slim aan bestaande systemen en workflows.
              </p>
            </dd>
          </div>
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                4
              </div>
              Training & support
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>
                Jouw team leert ermee werken, wij blijven beschikbaar voor
                ondersteuning.
              </p>
            </dd>
          </div>
          <div class='flex flex-col'>
            <dt
              class='flex items-center gap-x-3 text-base font-semibold leading-7 text-gray-900'
            >
              <div
                class='h-10 w-10 flex-none rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold'
              >
                5
              </div>
              Optimalisatie
            </dt>
            <dd
              class='mt-4 flex flex-auto flex-col text-base leading-7 text-gray-600'
            >
              <p class='flex-auto'>We meten de impact en verbeteren continu.</p>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </div>

  <CallToActionSimple>
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
      Laat je bedrijf draaien op slimme technologie
    </h2>
    <p class="mx-auto mt-6 max-w-xl text-lg leading-8">
      AI is geen toekomstmuziek. Het is er al – en jij kunt er vandaag van profiteren.
    </p>
    <p class="mx-auto mt-4 max-w-xl text-lg leading-8">
      Vraag een vrijblijvende AI-scan aan en ontdek wat "meer doen met minder" in jouw context betekent.
    </p>
    <div class="mt-10 flex items-center justify-center gap-x-6">
      <Button href="/nl/contact">
        Plan een verkennend gesprek
      </Button>
    </div>
  </CallToActionSimple>
</GlobalLayout>
