---
import GlobalLayout from '@/layouts/GlobalLayout.astro';
import ContactBlock from '@/components/ContactBlock.astro';
---

<GlobalLayout
  lang='nl'
  title='Contact'
  description='Neem contact op met Pixeau voor softwareontwikkeling, nearshoring en AI-oplossingen.'
>
  <ContactBlock
    title='Neem contact op'
    subtitle='Heeft u een vraag? Wilt u een vrijblijvend kennismakingsgesprek inplannen? Of bent u benieuwd naar wat wij voor u kunnen betekenen? Vul onderstaande velden in en druk op verzenden. We nemen zo spoedig mogelijk contact met u op.'
    submitButtonText='Verzenden'
  />
</GlobalLayout>
