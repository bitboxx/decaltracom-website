---
import GlobalLayout from '../layouts/GlobalLayout.astro';
---

<GlobalLayout
  title='Page not found'
  description="The page you're looking for couldn't be found."
>
  <!-- English content -->
  <div id='content-en' class='flex items-center justify-center min-h-[75vh]'>
    <div class='text-center px-6 py-24'>
      <p class='text-base font-semibold text-primary-500'>404</p>
      <h1
        class='mt-4 text-5xl font-semibold tracking-tight text-balance text-gray-900 sm:text-7xl'
      >
        Page not found
      </h1>
      <p
        class='mt-6 text-lg font-medium text-pretty text-gray-500 sm:text-xl/8'
      >
        Sorry, we couldn't find the page you're looking for.
      </p>
    </div>
  </div>

  <!-- Dutch content -->
  <div
    id='content-nl'
    style='display: none;'
    class='flex items-center justify-center min-h-[75vh]'
  >
    <div class='text-center px-6 py-24'>
      <p class='text-base font-semibold text-primary-500'>404</p>
      <h1
        class='mt-4 text-5xl font-semibold tracking-tight text-balance text-gray-900 sm:text-7xl'
      >
        Pagina niet gevonden
      </h1>
      <p
        class='mt-6 text-lg font-medium text-pretty text-gray-500 sm:text-xl/8'
      >
        Sorry, we konden de pagina die je zocht niet vinden.
      </p>
    </div>
  </div>
</GlobalLayout>

<script>
  // Detect browser language and show appropriate content
  const browserLang = navigator.language;
  const isNL = browserLang?.startsWith('nl') || false;

  const contentEn = document.getElementById('content-en');
  const contentNl = document.getElementById('content-nl');
  const htmlElement = document.documentElement;

  if (isNL && contentEn && contentNl) {
    // Show Dutch content
    contentEn.style.display = 'none';
    contentNl.style.display = 'flex';
    htmlElement.lang = 'nl';
    document.title = 'Pagina niet gevonden';
  } else if (contentEn && contentNl) {
    // Show English content (default)
    contentEn.style.display = 'flex';
    contentNl.style.display = 'none';
    htmlElement.lang = 'en';
    document.title = 'Page not found';
  }
</script>
